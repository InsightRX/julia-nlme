;; 1. Based on: 18
$PROBLEM    run15 + but CrCL using FFM. Don't estimate FFM~V1/V2
$INPUT      ID OCC TIME EVID MDV DV AMT LENGTH RATE DROP DROP SEX AGE
            WEIGHT HEIGHT CREAT LOGCR LOGWT70 FFM LOGFFM70
$DATA      ../data/nmdata_20230216_1.csv IGNORE=@
$SUBROUTINE ADVAN3 TRANS4
$PK
CRCL = (140-AGE) * FFM * (0.85**SEX) / (72*CREAT)
TVCL = THETA(1) * (FFM/70)**THETA(7) * (CRCL/100)**THETA(9)
CL = TVCL * EXP(ETA(1))
TVV1 = THETA(2) * (FFM/70)**THETA(8)
V1 = TVV1 * EXP(ETA(2))
TVQ = THETA(3) * (FFM/70)**THETA(7)
Q = TVQ
TVV2 = THETA(4) * (FFM/70)**THETA(8)
V2 = TVV2 * EXP(ETA(3))
S1 = V1

IF(NEWIND.NE.2) THEN
  TAD = 0
  TLASTDOSE = 0
ENDIF
IF(EVID.EQ.1) TLASTDOSE = TIME
TAD = TIME - TLASTDOSE

;$DES
;DADT(1) = -(CL/V1)*A(1) + (Q/V2)*A(2) - (Q/V1)*A(1)
;DADT(2) =               - (Q/V2)*A(2) + (Q/V1)*A(1)
;DADT(3) =  (A(1)/V1)

$ERROR
CONC = A(1)/S1
IPRED = CONC
PROP = THETA(5)
ADD = THETA(6)
W = SQRT(IPRED**2 * PROP**2 + ADD**2)
IRES = DV - IPRED
IWRES = IRES/W
Y = IPRED + W*ERR(1)
AUC = A(3)

$THETA  (0.1,5.35466) ; CL
 (1,70.3004) ; V1
 (0.1,5.39354) ; Q
 (1,64.4624) ; V2
 (0,0.136507) ; prop error
 (0,1.07081) ; add error
 0 FIX ; allo CL/Q
 1 FIX ; allo V1/V2
 (0.01,0.865302) ; CRCL ~ CL
$OMEGA  BLOCK(3)
 0.0708442
 0.0523489 0.0851515
 0.0106371 0.087445 0.565006
$SIGMA  1  FIX
$ESTIMATION METHOD=1 INTER MAXEVAL=9999 PRINT=5 POSTHOC NOABORT
$COVARIANCE UNCOND
$TABLE      ID TIME DV MDV EVID PRED IPRED IRES IWRES CWRES NPDE
            WEIGHT FFM HEIGHT SEX AGE CREAT CRCL CL V1 Q V2 ETA(1)
            ETA(2) ETA(3) NOPRINT NOAPPEND FILE=run18_proseval.tab

